{
    "name": "Dev Container Template",
    
    "build": {
      "dockerfile": "Dockerfile",
      "context": ".."
    },

    "workspaceFolder": "/workspace",
    "forwardPorts": [8080],
    "portsAttributes": {
      "8000": {
        "label": "Web App",
        "onAutoForward": "openBrowser"
      }
    },
    
    "postCreateCommand": "chmod +x ../setup.sh && ../setup.sh",
    
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-python.python",
          "ms-python.vscode-pylance"
        ]
      }
    }
  }