{
    "name": "yourapp-dev",
    "build": {
      "dockerfile": "Dockerfile",
      "context": ".."
    },
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    "forwardPorts": [8080],
    "init": true,
    "mounts": [
      "source=${localWorkspaceFolder}/config/secrets,target=/run/secrets,type=bind,consistency=cached"
    ],
    "runArgs": [
      "--cap-add=SYS_PTRACE",
      "--security-opt=seccomp=unconfined"
    ],
    "customizations": {
      "vscode": {
        "extensions": [
          "ms-python.python",
          "charliermarsh.ruff",
          "detachhead.basedpyright"
        ],
        "settings": {
          "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
          "python.testing.pytestEnabled": true,
          "python.testing.unittestEnabled": false,
          "python.testing.pytestArgs": ["tests"],
          "editor.formatOnSave": true,
          "[python]": {
            "editor.defaultFormatter": "charliermarsh.ruff",
            "editor.codeActionsOnSave": {
              "source.fixAll.ruff": "explicit",
              "source.organizeImports.ruff": "explicit"
            }
          }
        }
      }
    },
    "postCreateCommand": "bash -lc 'python -m venv .venv && source .venv/bin/activate && python -m pip install --upgrade pip && python -m pip install --require-hashes -r requirements-dev.txt && python -m pip install -e . --no-deps'"
  }